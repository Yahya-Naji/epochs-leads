# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────

# ── VAPI ────────────────────────────────────────────
# Dashboard: https://dashboard.vapi.ai → Account → API Keys

# Private key (server-side only — never expose in browser)
VAPI_API_KEY=vapi_...

# Public key (safe for browser — used by web demo mode)
NEXT_PUBLIC_VAPI_API_KEY=...

# Assistant ID — create your assistant manually in VAPI dashboard,
# then paste the ID here. Used by both web calls and phone calls.
# Server env var (for phone calls via API route):
VAPI_ASSISTANT_ID=
# Public env var (for web demo in browser):
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# Phone Number ID — only needed for outbound Phone Call mode
# Dashboard: Phone Numbers → buy or import a number → copy its ID
VAPI_PHONE_NUMBER_ID=

# ── Airtable ─────────────────────────────────────────
# Token: https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=pat...

# Base ID from the URL: airtable.com/appXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXX

# Table name inside the base (default: Leads)
AIRTABLE_TABLE_NAME=Leads
